# Database
DATABASE_URL="postgresql://user:password@localhost:5432/themoak_erp?schema=public"

# NextAuth - Required for authentication (minimum 32 characters)
# You can use either AUTH_SECRET (v5) or NEXTAUTH_SECRET (v4)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# NextAuth URL (optional, auto-detected on Vercel)
# Only needed if you have custom domain issues
AUTH_URL="https://yourdomain.com"

# WooCommerce Integration (optional)
WOOCOMMERCE_URL="https://your-woocommerce-site.com"
WOOCOMMERCE_CONSUMER_KEY="ck_xxxxxxxxxxxxx"
WOOCOMMERCE_CONSUMER_SECRET="cs_xxxxxxxxxxxxx"
